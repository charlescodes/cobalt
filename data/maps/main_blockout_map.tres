[resource]
script = ExtResource("1_map")
map_id = "main_blockout"
grounds = Array[ExtResource("2_ground")]([SubResource("Resource_ground")])
static_walls = Array[ExtResource("3_wall")]([SubResource("Resource_wall_corner_segment"), SubResource("Resource_wall_side_segment")])
